{
  "rewrites": [
    { "source": "/", "destination": "/api/page" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Link",
          "value": "</.well-known/api-catalog>; rel=\"api-catalog\", <https://seenly.studio/>; rel=\"service-doc\""
        },
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    }
  ]
}
